code = "shader_type canvas_item;
render_mode blend_premul_alpha, unshaded;

uniform float Size : hint_range(0.25, 4) = 1;
uniform sampler2D Texture2DParameter : hint_default_black, filter_linear, repeat_enable;
uniform float Saturation : hint_range(0, 1) = 1;
uniform float Amount : hint_range(0, 1) = 0.5;



void fragment() {
// Input:7
	vec2 n_out7p0 = SCREEN_UV;


// Input:6
	vec2 n_out6p0 = SCREEN_PIXEL_SIZE;


// VectorOp:8
	vec2 n_out8p0 = n_out7p0 / n_out6p0;


// FloatParameter:35
	float n_out35p0 = Size;


// FloatOp:36
	float n_in36p0 = 256.00000;
	float n_out36p0 = n_in36p0 * n_out35p0;


// VectorOp:14
	vec2 n_out14p0 = n_out8p0 / vec2(n_out36p0);


// Input:19
	float n_out19p0 = TIME;


// VectorOp:22
	vec2 n_in22p1 = vec2(72.99300, 11.92900);
	vec2 n_out22p0 = vec2(n_out19p0) * n_in22p1;


// VectorOp:20
	vec2 n_out20p0 = n_out14p0 + n_out22p0;


// MultiplyAdd:42
	vec2 n_in42p1 = vec2(0.80000, 0.80000);
	vec2 n_in42p2 = vec2(0.44000, 0.74000);
	vec2 n_out42p0 = fma(n_out20p0, n_in42p1, n_in42p2);


	vec4 n_out39p0;
// Texture2D:39
	n_out39p0 = texture(Texture2DParameter, n_out42p0);


// MultiplyAdd:41
	vec2 n_in41p1 = vec2(0.60000, 0.60000);
	vec2 n_in41p2 = vec2(0.30000, 0.82000);
	vec2 n_out41p0 = fma(n_out20p0, n_in41p1, n_in41p2);


	vec4 n_out40p0;
// Texture2D:40
	n_out40p0 = texture(Texture2DParameter, n_out41p0);


	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(Texture2DParameter, n_out20p0);


// VectorCompose:43
	vec3 n_out43p0 = vec3(n_out40p0.x, n_out39p0.x, n_out3p0.x);


// FloatParameter:52
	float n_out52p0 = Saturation;


// Mix:51
	vec3 n_out51p0 = mix(vec3(n_out39p0.xyz), n_out43p0, vec3(n_out52p0));


// FloatParameter:53
	float n_out53p0 = Amount;


// VectorOp:44
	vec3 n_out44p0 = n_out51p0 * vec3(n_out53p0);


// FloatConstant:55
	float n_out55p0 = 1.800000;


// VectorOp:54
	vec3 n_out54p0 = pow(n_out44p0, vec3(n_out55p0));


// DerivativeFunc:57
	vec3 n_out57p0 = dFdy(n_out51p0);


// FloatFunc:59
	float n_out59p0 = 1.0 - n_out57p0.x;


// FloatOp:58
	float n_out58p0 = n_out59p0 * n_out53p0;


// FloatOp:56
	float n_out56p0 = pow(n_out58p0, n_out55p0);


// Output:0
	COLOR.rgb = n_out54p0;
	COLOR.a = n_out56p0;


}
