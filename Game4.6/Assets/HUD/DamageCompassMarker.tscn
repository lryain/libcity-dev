[sub_resource type="VisualShader" id="VisualShader_uirqk"]
code = "shader_type canvas_item;
render_mode blend_mix;

uniform sampler2D screen_tex_frg_3 : hint_screen_texture;



void fragment() {
// Input:2
	vec2 n_out2p0 = SCREEN_UV;


// FloatConstant:4
	float n_out4p0 = 2.500000;


	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = textureLod(screen_tex_frg_3, n_out2p0, n_out4p0);


// Input:5
	vec4 n_out5p0 = COLOR;


// VectorDecompose:7
	float n_out7p0 = n_out5p0.x;
	float n_out7p1 = n_out5p0.y;
	float n_out7p2 = n_out5p0.z;
	float n_out7p3 = n_out5p0.w;


// Mix:9
	vec3 n_out9p0 = mix(vec3(n_out3p0.xyz), vec3(n_out5p0.xyz), vec3(n_out7p3));


// FloatOp:8
	float n_in8p1 = 0.50000;
	float n_out8p0 = pow(n_out7p3, n_in8p1);


// Output:0
	COLOR.rgb = n_out9p0;
	COLOR.a = n_out8p0;


}
