code = "shader_type canvas_item;
uniform sampler2D tex_frg_2;



void fragment() {
// Input:5
	vec4 n_out5p0 = COLOR;


// VectorDecompose:3
	float n_out3p0 = n_out5p0.x;
	float n_out3p1 = n_out5p0.y;
	float n_out3p2 = n_out5p0.z;
	float n_out3p3 = n_out5p0.w;


// Input:7
	vec2 n_out7p0 = SCREEN_UV;


// UVFunc:8
	vec2 n_in8p1 = vec2(1.00000, 1.00000);
	vec2 n_in8p2 = vec2(0.00000, -0.50000);
	vec2 n_out8p0 = fma(n_in8p2, n_in8p1, n_out7p0);


// Texture2D:2
	vec4 n_out2p0 = texture(tex_frg_2, n_out8p0);


// FloatOp:6
	float n_out6p0 = n_out3p3 * n_out2p0.x;


// Output:0
	COLOR.rgb = vec3(n_out5p0.xyz);
	COLOR.a = n_out6p0;


}
"
