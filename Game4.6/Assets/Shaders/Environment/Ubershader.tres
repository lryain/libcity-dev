[resource]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_schlick_ggx;

global uniform bool height_mapping_enabled;
uniform bool HeightMappingEnabled;
uniform float HeightScale = 0.25;
uniform vec2 HeightOcclusionLayersRange = vec2(4.000000, 16.000000);
global uniform vec2 height_mapping_layers_range_limit;
uniform sampler2D Height : filter_linear_mipmap_anisotropic;
global uniform bool height_mapping_occlusion_enabled;
uniform bool HeightMappingOcclusion = false;
uniform float Scale = 32;
uniform sampler2D Warp : hint_default_transparent, filter_linear;
uniform float WarpScale = 0.5;
uniform float WarpAmount = 0.00999999977648;
uniform sampler2D BaseColor : source_color, filter_linear_mipmap_anisotropic;
uniform vec4 BaseColorOver : source_color = vec4(0.609330, 0.609330, 0.609330, 1.000000);
uniform float MacroWarpAmount = 0.02500000037253;
uniform float MacroRotation = 1.25;
uniform float ScaleMacro1 = 2.29999995231628;
uniform sampler2D Macro : filter_linear_mipmap_anisotropic;
uniform float ScaleMacro2 = 3.22000002861023;
uniform sampler2D ORMD : hint_default_transparent, filter_linear_mipmap_anisotropic;
uniform float BaseColorMacro = 0.75;
uniform float OverlayWarpAmount = 0.00999999977648;
uniform float OverlayScale = 0.5;
uniform sampler2D OverlayBaseColor : source_color, hint_default_transparent;
uniform float Overlay_Macro_Mask : hint_range(0, 1) = 1;
uniform vec2 Overlay_Mask_Input_Remap = vec2(0.000000, 1.000000);
uniform float OverlayAmount : hint_range(0, 1) = 0;
uniform sampler2D OverlayORM : hint_default_transparent;
uniform float RoughnessMacro = 0.25;
uniform sampler2D OverlayNormal : hint_normal;
uniform sampler2D Normal : hint_normal, filter_linear_mipmap_anisotropic;
uniform float NormalMacro = 0.5;
uniform float NormalDepth = 1;
uniform bool AlphaScissor = false;
uniform float AlphaScissorThreshold = 0.5;



void fragment() {
// BooleanParameter:163
	bool n_out163p0 = height_mapping_enabled;


// BooleanParameter:146
	bool n_out146p0 = HeightMappingEnabled;


	bool n_out162p0;
// Switch:162
	bool n_in162p2 = false;
	if (n_out163p0) {
		n_out162p0 = n_out146p0;
	} else {
		n_out162p0 = n_in162p2;
	}


// Input:8
	vec2 n_out8p0 = UV;


// FloatParameter:145
	float n_out145p0 = HeightScale;


// Vector2Parameter:147
	vec2 n_out147p0 = HeightOcclusionLayersRange;


// Vector2Parameter:167
	vec2 n_out167p0 = height_mapping_layers_range_limit;


// VectorOp:168
	vec2 n_out168p0 = min(n_out147p0, n_out167p0);


// VectorDecompose:148
