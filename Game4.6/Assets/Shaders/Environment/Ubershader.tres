nodes/fragment/142/input_ports = "0,3,UV;1,0,heightmap_scale;2,1,heightmap_min_layers;3,1,heightmap_max_layers;4,3,heightmap_flip;5,8,texture_heightmap;6,6,occlusion;7,0,uv_scale;8,8,texture_warp;9,0,warp_scale;10,0,warp_amount;"
nodes/fragment/142/output_ports = "0,3,out_uv;"
nodes/fragment/142/expression = "// NOTE: code adapted from Godot Engine 4.0.1.stable's StandardMaterial3D.
vec2 base_uv = UV;
vec3 view_dir = normalize(normalize(-VERTEX) * mat3(TANGENT * heightmap_flip.x, -BINORMAL * heightmap_flip.y, NORMAL));
vec2 ofs;
if (occlusion == false) { // height mapping
	vec2 warp_offset = (texture(texture_warp, base_uv * warp_scale).rg * 2.0 - 1.0) * warp_amount;
	float depth = 1.0 - texture(texture_heightmap, (base_uv + warp_offset) * uv_scale).r;
	ofs = base_uv - view_dir.xy * depth * heightmap_scale * 0.01;
}
else { // parallax occlusion mapping0.002
	//uv_scale = 32.0;
	//heightmap_scale *= 1.0;
	float num_layers = mix(float(heightmap_max_layers),float(heightmap_min_layers), abs(dot(vec3(0.0, 0.0, 1.0), view_dir)));
	float layer_depth = 1.0 / num_layers;
	float current_layer_depth = 0.0;
	vec2 P = view_dir.xy * heightmap_scale * 0.01;
	vec2 delta = P / num_layers;
	ofs = base_uv;
	vec2 warp_offset = (texture(texture_warp, ofs * warp_scale).rg * 2.0 - 1.0) * warp_amount;
	float depth = 1.0 - texture(texture_heightmap, (ofs + warp_offset) * uv_scale).r;
	float current_depth = 0.0;
	while(current_depth < depth) {
		ofs -= delta;
		warp_offset = (texture(texture_warp, ofs * warp_scale).rg * 2.0 - 1.0) * warp_amount;
		depth = 1.0 - texture(texture_heightmap, (ofs + warp_offset) * uv_scale).r;
		current_depth += layer_depth;
	}
	vec2 prev_ofs = ofs + delta;
	float after_depth  = depth - current_depth;
	warp_offset = (texture(texture_warp, ofs * warp_scale).rg * 2.0 - 1.0) * warp_amount;
	float before_depth = ( 1.0 - texture(texture_heightmap, (prev_ofs + warp_offset) * uv_scale).r ) - current_depth + layer_depth;

	float weight = after_depth / (after_depth - before_depth);
	ofs = mix(ofs, prev_ofs, weight);
} ;
//debug_out = texture(texture_warp, ofs * warp_scale).rgb;
out_uv = ofs;"
