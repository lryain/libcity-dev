code = "shader_type spatial;
render_mode blend_mix, depth_draw_never, cull_disabled, diffuse_lambert, specular_disabled, shadows_disabled, vertex_lighting;

uniform sampler2D tex_frg_2;
uniform sampler2D curve_frg_22 : repeat_disable;
uniform sampler2D tex_frg_10;
uniform sampler2D tex_frg_28;
uniform sampler2D curve_frg_40 : repeat_disable;
uniform sampler2D curve_frg_3 : repeat_disable;



void vertex() {
// Input:2
	vec2 n_out2p0 = UV;


// Distance:12
	vec2 n_in12p1 = vec2(0.50000, 0.50000);
	float n_out12p0 = distance(n_out2p0, n_in12p1);


// SmoothStep:32
	float n_in32p0 = 0.10000;
	float n_in32p1 = 0.75000;
	float n_out32p0 = smoothstep(n_in32p0, n_in32p1, n_out12p0);


// Input:3
	vec3 n_out3p0 = VERTEX;


// MultiplyAdd:10
	vec3 n_in10p1 = vec3(0.00000, -200.00000, 0.00000);
	vec3 n_out10p0 = fma(vec3(n_out32p0), n_in10p1, n_out3p0);


// Input:20
	vec4 n_out20p0 = COLOR;


// FloatOp:25
	float n_in25p1 = 8.00000;
	float n_out25p0 = n_out20p0.x * n_in25p1;


// Input:14
	float n_out14p0 = TIME;


// FloatOp:24
	float n_in24p1 = 1.50000;
	float n_out24p0 = n_out14p0 * n_in24p1;


// FloatOp:21
	float n_out21p0 = n_out25p0 + n_out24p0;


// FloatFunc:22
	float n_out22p0 = sin(n_out21p0);


// MultiplyAdd:23
	float n_in23p1 = 0.15000;
	float n_in23p2 = 0.75000;
	float n_out23p0 = fma(n_out22p0, n_in23p1, n_in23p2);


// VectorCompose:19
	float n_in19p1 = 1.00000;
	vec3 n_out19p0 = vec3(n_out23p0, n_in19p1, n_out23p0);


// VectorOp:18
	vec3 n_out18p0 = n_out10p0 * n_out19p0;


// Compare:33
	float n_in33p1 = 0.50000;
	bool n_out33p0 = n_out12p0 < n_in33p1;


	float n_out34p0;
// Switch:34
	float n_in34p1 = 1.00000;
	float n_in34p2 = 0.00000;
	n_out34p0 = mix(n_in34p2, n_in34p1, float(n_out33p0));


// Output:0
	VERTEX = n_out18p0;
	COLOR.a = n_out34p0;


}

void fragment() {
// BooleanConstant:53
	bool n_out53p0 = true;


// Texture2D:2
	vec4 n_out2p0 = texture(tex_frg_2, UV);


// Input:5
	vec4 n_out5p0 = COLOR;


// FloatOp:8
	float n_in8p1 = 4.00000;
	float n_out8p0 = n_out5p0.x * n_in8p1;


// Input:24
	float n_out24p0 = TIME;


// MultiplyAdd:26
	float n_in26p1 = 0.25000;
	float n_in26p2 = 0.00000;
	float n_out26p0 = fma(n_out24p0, n_in26p1, n_in26p2);


// FloatFunc:25
	float n_out25p0 = sin(n_out26p0);


// FloatOp:27
	float n_out27p0 = n_out8p0 + n_out25p0;


// FloatFunc:6
	float n_out6p0 = sin(n_out27p0);


	float n_out9p0;
// Remap:9
	float n_in9p1 = -1.00000;
	float n_in9p2 = 1.00000;
	float n_in9p3 = 0.50000;
	float n_in9p4 = 2.00000;
	{
		float __input_range = n_in9p2 - n_in9p1;
		float __output_range = n_in9p4 - n_in9p3;
		n_out9p0 = n_in9p3 + __output_range * ((n_out6p0 - n_in9p1) / __input_range);
	}


// FloatOp:7
	float n_out7p0 = n_out2p0.x * n_out9p0;


// CurveTexture:22
	float n_out22p0 = texture(curve_frg_22, vec2(n_out7p0)).r;


// Input:32
	float n_out32p0 = TIME;


// Input:35
	vec4 n_out35p0 = COLOR;


// FloatOp:34
	float n_in34p1 = -2.00000;
	float n_out34p0 = n_out35p0.x * n_in34p1;


// FloatOp:36
	float n_out36p0 = n_out32p0 + n_out34p0;


// Input:17
	vec2 n_out17p0 = UV;


// Vector2Constant:18
	vec2 n_out18p0 = vec2(0.500000, 0.500000);


// Input:4
	float n_out4p0 = TIME;


// FloatOp:15
	float n_in15p1 = -4.00000;
	float n_out15p0 = n_out5p0.x * n_in15p1;


// FloatOp:19
	float n_out19p0 = n_out4p0 + n_out15p0;


	vec2 n_out16p0;
// Expression:16
	n_out16p0 = vec2(0.0, 0.0);
	{
		n_out16p0.x = cos(n_out19p0) * (n_out17p0.x - n_out18p0.x) + sin(n_out19p0) * (n_out17p0.y - n_out18p0.y) + n_out18p0.x;
		n_out16p0.y = cos(n_out19p0) * (n_out17p0.y - n_out18p0.y) - sin(n_out19p0) * (n_out17p0.x - n_out18p0.x) + n_out18p0.y;
	}


// Texture2D:10
	vec4 n_out10p0 = texture(tex_frg_10, n_out16p0);


// FloatOp:37
	float n_out37p0 = n_out36p0 + n_out10p0.x;


// MultiplyAdd:31
	float n_in31p1 = 0.50000;
	float n_out31p0 = fma(n_out7p0, n_in31p1, n_out37p0);


// Texture2D:28
	vec4 n_out28p0 = texture(tex_frg_28, vec2(n_out31p0));


// MultiplyAdd:23
	vec3 n_in23p2 = vec3(0.00000, 0.00000, 0.00000);
	vec3 n_out23p0 = fma(vec3(n_out22p0), vec3(n_out28p0.xyz), n_in23p2);


// FloatConstant:30
	float n_out30p0 = 15.000000;


// VectorOp:29
	vec3 n_out29p0 = n_out23p0 * vec3(n_out30p0);


	vec2 n_out50p0;
// Switch:50
	vec2 n_in50p2 = vec2(1.00000, 1.00000);
	n_out50p0 = mix(n_in50p2, vec2(n_out29p0.xy), float(n_out53p0));


// Input:41
	vec4 n_out41p0 = COLOR;


// CurveTexture:40
	float n_out40p0 = texture(curve_frg_40, vec2(n_out41p0.x)).r;


// CurveTexture:3
	float n_out3p0 = texture(curve_frg_3, vec2(n_out7p0)).r;


// FloatOp:13
	float n_out13p0 = n_out3p0 * n_out10p0.x;


// Fresnel:38
	float n_in38p3 = 1.00000;
	float n_out38p0 = pow(1.0 - clamp(dot(NORMAL, VIEW), 0.0, 1.0), n_in38p3);


// FloatOp:39
	float n_out39p0 = n_out13p0 * n_out38p0;


// SmoothStep:51
	float n_in51p0 = 0.00000;
	float n_in51p1 = 0.75000;
	float n_out51p0 = smoothstep(n_in51p0, n_in51p1, n_out39p0);


// FloatOp:42
	float n_out42p0 = n_out40p0 * n_out51p0;


	float n_out52p0;
// Switch:52
	float n_in52p2 = 1.00000;
	n_out52p0 = mix(n_in52p2, n_out42p0, float(n_out53p0));


// Output:0
	ALBEDO = vec3(n_out50p0, 0.0);
	ALPHA = n_out52p0;


}
