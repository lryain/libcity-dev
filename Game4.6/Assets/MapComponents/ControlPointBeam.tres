code = "shader_type spatial;
render_mode blend_add, depth_draw_opaque, cull_disabled, diffuse_lambert, specular_schlick_ggx, unshaded, fog_disabled;

uniform sampler2D tex_frg_26;
instance uniform int team : hint_range(0, 2, 1);
global uniform vec4 team_color_0 : source_color;
global uniform vec4 team_color_1 : source_color;
global uniform vec4 team_color_2 : source_color;



void fragment() {
// Input:4
	vec2 n_out4p0 = UV;


// VectorDecompose:5
	float n_out5p0 = n_out4p0.x;
	float n_out5p1 = n_out4p0.y;


// FloatOp:13
	float n_in13p1 = 5.00000;
	float n_out13p0 = pow(n_out5p1, n_in13p1);


// FloatOp:16
	float n_in16p1 = 16.00000;
	float n_out16p0 = n_out13p0 * n_in16p1;


// Input:6
	float n_out6p0 = TIME;


// FloatOp:11
	float n_in11p1 = 25.00000;
	float n_out11p0 = n_out6p0 * n_in11p1;


// MultiplyAdd:7
	float n_in7p1 = 200.00000;
	float n_out7p0 = fma(n_out5p1, n_in7p1, n_out11p0);


// FloatFunc:8
	float n_out8p0 = sin(n_out7p0);


	float n_out9p0;
// Remap:9
	float n_in9p1 = -1.00000;
	float n_in9p2 = 1.00000;
	float n_in9p3 = 0.00000;
	float n_in9p4 = 1.00000;
	{
		float __input_range = n_in9p2 - n_in9p1;
		float __output_range = n_in9p4 - n_in9p3;
		n_out9p0 = n_in9p3 + __output_range * ((n_out8p0 - n_in9p1) / __input_range);
	}


// Mix:10
	float n_out10p0 = mix(n_out16p0, n_out9p0, n_out16p0);


// MultiplyAdd:28
	float n_in28p1 = 0.05000;
	float n_out28p0 = fma(n_out6p0, n_in28p1, n_out5p0);


// FloatOp:30
	float n_in30p1 = 0.10000;
	float n_out30p0 = n_out6p0 * n_in30p1;


// VectorCompose:29
	vec2 n_out29p0 = vec2(n_out28p0, n_out30p0);


// Texture2D:26
	vec4 n_out26p0 = texture(tex_frg_26, n_out29p0);


	vec3 n_out27p0;
// ColorOp:27
	{
		float base = vec3(n_out10p0).x;
		float blend = vec3(n_out26p0.xyz).x;
		if (base < 0.5) {
			n_out27p0.x = 2.0 * base * blend;
		} else {
			n_out27p0.x = 1.0 - 2.0 * (1.0 - blend) * (1.0 - base);
		}
	}
	{
		float base = vec3(n_out10p0).y;
		float blend = vec3(n_out26p0.xyz).y;
		if (base < 0.5) {
			n_out27p0.y = 2.0 * base * blend;
		} else {
			n_out27p0.y = 1.0 - 2.0 * (1.0 - blend) * (1.0 - base);
		}
	}
	{
		float base = vec3(n_out10p0).z;
		float blend = vec3(n_out26p0.xyz).z;
		if (base < 0.5) {
			n_out27p0.z = 2.0 * base * blend;
		} else {
			n_out27p0.z = 1.0 - 2.0 * (1.0 - blend) * (1.0 - base);
		}
	}


// IntParameter:20
	int n_out20p0 = team;


// Compare:25
	int n_in25p1 = 2;
	bool n_out25p0 = n_out20p0 < n_in25p1;


// Compare:22
	int n_in22p1 = 1;
	bool n_out22p0 = n_out20p0 < n_in22p1;


// ColorParameter:19
	vec4 n_out19p0 = team_color_0;


// ColorParameter:2
	vec4 n_out2p0 = team_color_1;


	vec3 n_out18p0;
// Switch:18
	n_out18p0 = mix(vec3(n_out2p0.xyz), vec3(n_out19p0.xyz), float(n_out22p0));


// ColorParameter:21
	vec4 n_out21p0 = team_color_2;


	vec3 n_out24p0;
// Switch:24
	n_out24p0 = mix(vec3(n_out21p0.xyz), n_out18p0, float(n_out25p0));


// VectorOp:12
	vec3 n_out12p0 = n_out27p0 * n_out24p0;


// Clamp:31
	vec3 n_in31p1 = vec3(0.00000, 0.00000, 0.00000);
	vec3 n_in31p2 = vec3(3.00000, 3.00000, 3.00000);
	vec3 n_out31p0 = clamp(n_out12p0, n_in31p1, n_in31p2);


// Output:0
	ALBEDO = n_out31p0;


}
