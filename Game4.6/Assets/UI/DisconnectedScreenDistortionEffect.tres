[sub_resource type="VisualShader" id="VisualShader_sjj4f"]
code = "shader_type canvas_item;
render_mode unshaded;

uniform float Size : hint_range(0.25, 4) = 1;
uniform vec2 Speed = vec2(72.880997, 23.292000);
uniform sampler2D Noise : hint_default_black, filter_nearest, repeat_enable;
uniform float Saturation : hint_range(0, 1) = 1;


// GlobalExpression:0
	uniform sampler2D screen : hint_screen_texture, filter_linear_mipmap;

void fragment() {
// Input:7
	vec2 n_out7p0 = SCREEN_UV;


// Input:6
	vec2 n_out6p0 = SCREEN_PIXEL_SIZE;


// VectorOp:8
	vec2 n_out8p0 = n_out7p0 / n_out6p0;


// FloatParameter:35
	float n_out35p0 = Size;


// FloatOp:36
	float n_in36p0 = 256.00000;
	float n_out36p0 = n_in36p0 * n_out35p0;


// VectorOp:14
	vec2 n_out14p0 = n_out8p0 / vec2(n_out36p0);


// Input:19
	float n_out19p0 = TIME;


// FloatConstant:106
	float n_out106p0 = 24.000000;


// FloatOp:105
	float n_out105p0 = n_out19p0 * n_out106p0;


// FloatFunc:104
	float n_out104p0 = trunc(n_out105p0);


// FloatOp:107
	float n_out107p0 = n_out104p0 / n_out106p0;


// FloatOp:109
	float n_in109p0 = 1.00000;
	float n_in109p1 = 1000.00000;
	float n_out109p0 = n_in109p0 / n_in109p1;


// Mix:108
	float n_out108p0 = mix(n_out107p0, n_out19p0, n_out109p0);


// FloatOp:103
	float n_in103p1 = 0.00000;
	float n_out103p0 = n_out108p0 + n_in103p1;


// Vector2Parameter:97
	vec2 n_out97p0 = Speed;


// VectorOp:22
	vec2 n_out22p0 = vec2(n_out103p0) * n_out97p0;


// VectorOp:20
	vec2 n_out20p0 = n_out14p0 + n_out22p0;


// MultiplyAdd:41
	vec2 n_in41p1 = vec2(0.60000, 0.60000);
	vec2 n_in41p2 = vec2(0.30000, 0.82000);
	vec2 n_out41p0 = fma(n_out20p0, n_in41p1, n_in41p2);


	vec4 n_out40p0;
// Texture2D:40
	n_out40p0 = texture(Noise, n_out41p0);


// MultiplyAdd:42
	vec2 n_in42p1 = vec2(0.80000, 0.80000);
	vec2 n_in42p2 = vec2(0.44000, 0.74000);
	vec2 n_out42p0 = fma(n_out20p0, n_in42p1, n_in42p2);


	vec4 n_out39p0;
// Texture2D:39
	n_out39p0 = texture(Noise, n_out42p0);


	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(Noise, n_out20p0);


// VectorCompose:43
	vec3 n_out43p0 = vec3(n_out40p0.x, n_out39p0.x, n_out3p0.x);


	vec3 n_out95p0;
// Expression:95
	n_out95p0 = vec3(0.0, 0.0, 0.0);
	{
		/*float quant = 3.0;
		Noise = round(n_out43p0 * quant) / quant;
		Noise.y = 0.0;
		//noise = n_out43p0;
		n_out95p0 = n_out7p0;*/
		
		vec2 uv = n_out7p0;
		
		uv.x += n_out103p0 / 15.0 + n_out7p0.y * 5.0;
		uv.x /= 50.0 + tan(n_out103p0 * 10.0) * 8.0;
		
		vec4 noise = texture (Noise, uv);
		
		noise = (round(noise * 11.0) / 11.0) * 0.9 - noise * 0.1;
		
		vec2 uv2 = n_out7p0;
		
		uv2.x += (noise.x - 0.5) / 10.0;
		
		vec2 of_g = vec2(sin(n_out103p0) / 100.0, 0);
		vec2 of_b = vec2(sin(n_out103p0 + 42.0) / 100.0, 0);
		float lod_r = sin(n_out103p0 + 2.0) + 1.0;
		float lod_g = sin(n_out103p0 + 3.0) + 1.0;
		float lod_b = sin(n_out103p0 + 4.0) + 1.0;
		
		vec4 col_r = textureLod (screen, uv2, lod_r);
		vec4 col_g = textureLod (screen, uv2 + of_g, lod_g);
		vec4 col_b = textureLod (screen, uv2 + of_b, lod_b);
		
		//n_out95p0.rgb = noise.rgb;
		n_out95p0.rgb = vec3(col_r.r, col_g.g, col_b.b);
	}


	vec3 n_out113p0;
// ColorFunc:113
	{
		vec3 c = n_out95p0;
		vec4 K = vec4(0.0, -1.0 / 3.0, 2.0 / 3.0, -1.0);
		vec4 p = mix(vec4(c.bg, K.wz), vec4(c.gb, K.xy), step(c.b, c.g));
		vec4 q = mix(vec4(p.xyw, c.r), vec4(c.r, p.yzx), step(p.x, c.r));
		float d = q.x - min(q.w, q.y);
		float e = 1.0e-10;
		n_out113p0 = vec3(abs(q.z + (q.w - q.y) / (6.0 * d + e)), d / (q.x + e), q.x);
	}


// VectorOp:114
	vec3 n_in114p1 = vec3(1.00000, 1.60000, 1.50000);
	vec3 n_out114p0 = n_out113p0 * n_in114p1;


	vec3 n_out112p0;
// ColorFunc:112
	{
		vec3 c = n_out114p0;
		vec4 K = vec4(1.0, 2.0 / 3.0, 1.0 / 3.0, 3.0);
		vec3 p = abs(fract(c.xxx + K.xyz) * 6.0 - K.www);
		n_out112p0 = c.z * mix(K.xxx, clamp(p - K.xxx, 0.0, 1.0), c.y);
	}


// SmoothStep:118
	vec3 n_in118p0 = vec3(0.00000, 0.00000, 0.00000);
	vec3 n_in118p1 = vec3(1.00000, 1.00000, 1.00000);
	vec3 n_out118p0 = smoothstep(n_in118p0, n_in118p1, n_out112p0);


// FloatParameter:52
	float n_out52p0 = Saturation;


// Mix:51
	vec3 n_out51p0 = mix(vec3(n_out39p0.xyz), n_out43p0, vec3(n_out52p0));


	vec3 n_out116p0;
// ColorFunc:116
	{
		vec3 c = n_out51p0;
		vec4 K = vec4(0.0, -1.0 / 3.0, 2.0 / 3.0, -1.0);
		vec4 p = mix(vec4(c.bg, K.wz), vec4(c.gb, K.xy), step(c.b, c.g));
		vec4 q = mix(vec4(p.xyw, c.r), vec4(c.r, p.yzx), step(p.x, c.r));
		float d = q.x - min(q.w, q.y);
		float e = 1.0e-10;
		n_out116p0 = vec3(abs(q.z + (q.w - q.y) / (6.0 * d + e)), d / (q.x + e), q.x);
	}


// VectorOp:117
	vec3 n_in117p1 = vec3(0.90000, 0.20000, 0.80000);
	vec3 n_out117p0 = n_out116p0 * n_in117p1;


	vec3 n_out115p0;
// ColorFunc:115
	{
		vec3 c = n_out117p0;
		vec4 K = vec4(1.0, 2.0 / 3.0, 1.0 / 3.0, 3.0);
		vec3 p = abs(fract(c.xxx + K.xyz) * 6.0 - K.www);
		n_out115p0 = c.z * mix(K.xxx, clamp(p - K.xxx, 0.0, 1.0), c.y);
	}


// FloatConstant:89
	float n_out89p0 = 0.300000;


// Mix:100
	vec3 n_out100p0 = mix(n_out118p0, n_out115p0, vec3(n_out89p0));


// Mix:101
	vec3 n_in101p1 = vec3(0.00000, 0.00000, 0.00000);
	vec3 n_in101p2 = vec3(0.50000, 0.50000, 0.50000);
	vec3 n_out101p0 = mix(n_out100p0, n_in101p1, n_in101p2);


// Output:0
	COLOR.rgb = n_out101p0;


}
"
