[sub_resource type="VisualShaderNodeExpression" id="VisualShaderNodeExpression_xmugu"]
size = Vector2(834.6, 929.76)
expression = "/*float quant = 3.0;
noise_in = round(in * quant) / quant;
noise_in.y = 0.0;
//noise = in;
out = screen_uv;*/

vec2 uv = screen_uv;

uv.x += time / 15.0 + screen_uv.y * 5.0;
uv.x /= 50.0 + tan(time * 10.0) * 8.0;

vec4 noise = texture (noise_in, uv);

noise = (round(noise * 11.0) / 11.0) * 0.9 - noise * 0.1;

vec2 uv2 = screen_uv;

uv2.x += (noise.x - 0.5) / 10.0;

vec2 of_g = vec2(sin(time) / 100.0, 0);
vec2 of_b = vec2(sin(time + 42.0) / 100.0, 0);
float lod_r = sin(time + 2.0) + 1.0;
float lod_g = sin(time + 3.0) + 1.0;
float lod_b = sin(time + 4.0) + 1.0;

vec4 col_r = textureLod (screen, uv2, lod_r);
vec4 col_g = textureLod (screen, uv2 + of_g, lod_g);
vec4 col_b = textureLod (screen, uv2 + of_b, lod_b);

//out.rgb = noise.rgb;
out.rgb = vec3(col_r.r, col_g.g, col_b.b);"

