[sub_resource type="VisualShaderNodeExpression" id="VisualShaderNodeExpression_hsj8n"]
size = Vector2(1140, 680)
expression = "vec2 index_uv = floor(vec2(uv.x * columns, uv.y * rows));
vec2 fract_uv = fract(vec2(uv.x * columns, uv.y * rows));

float minimum_dist = 1.0;  
vec2 minimum_point;
float dist = 0.0;
vec2 point;
vec2 neighbor;
vec2 diff;

for (int y= -1; y <= 1; y++) {
	for (int x= -1; x <= 1; x++) {
		neighbor = vec2(float(x),float(y));
		point = vec2(fract(sin(dot(index_uv + neighbor, vec2(12.98981, 78.511))) * 41078.5452123)) * 1.5;
		diff = neighbor + point - (fract_uv * 3.0);
		dist = length(diff);
		
		if(dist < minimum_dist) {
			minimum_dist = dist;
			minimum_point = point;
		}
	}
}

output = max(1.0 - pow(dist * 2.0, pow(point.x * point.y / 2.4, 16.0)), 0.0);"

