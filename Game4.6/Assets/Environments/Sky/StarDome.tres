[resource]
code = "shader_type spatial;
render_mode blend_add, depth_draw_never, cull_back, diffuse_lambert, specular_disabled, unshaded, shadows_disabled, fog_disabled;




void fragment() {
// Input:4
	vec2 n_out4p0 = UV;


// IntConstant:5
	int n_out5p0 = 1024;


// IntConstant:16
	int n_out16p0 = 512;


	float n_out3p0;
// Expression:3
	n_out3p0 = 0.0;
	{
		vec2 index_uv = floor(vec2(n_out4p0.x * float(n_out5p0), n_out4p0.y * float(n_out16p0)));
		vec2 fract_uv = fract(vec2(n_out4p0.x * float(n_out5p0), n_out4p0.y * float(n_out16p0)));
		
		float minimum_dist = 1.0;  
		vec2 minimum_point;
		float dist = 0.0;
		vec2 point;
		vec2 neighbor;
		vec2 diff;
		
		for (int y= -1; y <= 1; y++) {
			for (int x= -1; x <= 1; x++) {
				neighbor = vec2(float(x),float(y));
				point = vec2(fract(sin(dot(index_uv + neighbor, vec2(12.98981, 78.511))) * 41078.5452123)) * 1.5;
				diff = neighbor + point - (fract_uv * 3.0);
				dist = length(diff);
				
				if(dist < minimum_dist) {
					minimum_dist = dist;
					minimum_point = point;
				}
			}
		}
		
		n_out3p0 = max(1.0 - pow(dist * 2.0, pow(point.x * point.y / 2.4, 16.0)), 0.0);
	}


// Output:0
	ALBEDO = vec3(n_out3p0);


}
