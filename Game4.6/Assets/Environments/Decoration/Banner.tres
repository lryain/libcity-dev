[sub_resource type="VisualShaderNodeExpression" id="VisualShaderNodeExpression_olemy"]
size = Vector2(850.591, 617.888)
expression = "// glitch effect (by unfa)

// choosing vertical range of affected UV coordinates
float gate_low = mod( sin(time * 0.01) * 512.0, 1.0);
float gate_hi = mod(sin(time * 14.5) * 235.21, 1.0);

// additional chance of the effect being enabled
bool gate = ( mod(time / 32.04 + (time / 33.6) * 3.7, 1.0) > 0.98 );

if ( gate_low < uv.y && uv.y < gate_hi && gate)
	out.x = mix(mod(time, 1.0), uv.x, mod(sin(time * 0.03) * gate_low * gate_hi, 1.0) );
else
	// original cooridinates -> effect is off
	out.x = uv.x;
// we do not affect the vertiocal coordinates at all
out.y = uv.y;"

