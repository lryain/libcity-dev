code = "shader_type spatial;
render_mode blend_add, cull_disabled;

instance uniform float time_offset;
uniform sampler2D curve_frg_58 : repeat_disable;
uniform sampler2D Texture : source_color, hint_default_black, filter_nearest_mipmap, repeat_disable;
uniform float Emission = 1;



void fragment() {
// FloatConstant:78
	float n_out78p0 = 0.000000;


// FloatConstant:79
	float n_out79p0 = 1.000000;


// FloatParameter:65
	float n_out65p0 = time_offset;


// FloatOp:72
	float n_in72p0 = 0.00000;
	float n_out72p0 = n_in72p0 + n_out65p0;


// Input:51
	float n_out51p0 = TIME;


// FloatOp:69
	float n_out69p0 = n_out51p0 + n_out65p0;


// Input:46
	vec2 n_out46p0 = UV;


// VectorDecompose:47
	float n_out47p0 = n_out46p0.x;
	float n_out47p1 = n_out46p0.y;


// MultiplyAdd:52
	float n_in52p1 = 0.10000;
	float n_out52p0 = fma(n_out69p0, n_in52p1, n_out47p1);


// FloatOp:48
	float n_in48p1 = 1.50000;
	float n_out48p0 = n_out52p0 * n_in48p1;


// FloatFunc:49
	float n_out49p0 = tan(n_out48p0);


// Input:41
	float n_out41p0 = TIME;


// FloatOp:66
	float n_out66p0 = n_out41p0 + n_out65p0;


// Input:32
	vec2 n_out32p0 = UV;


// VectorDecompose:33
	float n_out33p0 = n_out32p0.x;
	float n_out33p1 = n_out32p0.y;


// FloatOp:35
	float n_in35p1 = 1000.00000;
	float n_out35p0 = n_out33p1 * n_in35p1;


// MultiplyAdd:42
	float n_in42p1 = 80.00000;
	float n_out42p0 = fma(n_out66p0, n_in42p1, n_out35p0);


// FloatFunc:36
	float n_out36p0 = sin(n_out42p0);


// FloatFunc:37
	float n_out37p0 = ceil(n_out36p0);


// FloatOp:80
	float n_in80p0 = 0.02000;
	float n_in80p1 = 0.01000;
	float n_out80p0 = n_in80p0 * n_in80p1;


// MultiplyAdd:38
	float n_out38p0 = fma(n_out37p0, n_out80p0, n_out33p0);


// MultiplyAdd:81
	float n_in81p1 = 0.00100;
	float n_out81p0 = fma(n_out37p0, n_in81p1, n_out33p1);


// VectorCompose:34
	vec2 n_out34p0 = vec2(n_out38p0, n_out81p0);


// VectorDecompose:45
	float n_out45p0 = n_out34p0.x;
	float n_out45p1 = n_out34p0.y;


// MultiplyAdd:50
	float n_in50p1 = 0.00200;
	float n_out50p0 = fma(n_out49p0, n_in50p1, n_out45p0);


// VectorCompose:44
	vec2 n_out44p0 = vec2(n_out50p0, n_out45p1);


	vec2 n_out70p0;
// Expression:70
	n_out70p0 = vec2(0.0, 0.0);
	{
		// glitch effect (by unfa)
		
		// choosing vertical range of affected UV coordinates
		float gate_low = mod( sin(n_out72p0 * 0.01) * 512.0, 1.0);
		float gate_hi = mod(sin(n_out72p0 * 14.5) * 235.21, 1.0);
		
		// additional chance of the effect being enabled
		bool gate = ( mod(n_out72p0 / 32.04 + (n_out72p0 / 33.6) * 3.7, 1.0) > 0.98 );
		
		if ( gate_low < n_out44p0.y && n_out44p0.y < gate_hi && gate)
			n_out70p0.x = mix(mod(n_out72p0, 1.0), n_out44p0.x, mod(sin(n_out72p0 * 0.03) * gate_low * gate_hi, 1.0) );
		else
			// original cooridinates -> effect is off
			n_out70p0.x = n_out44p0.x;
		// we do not affect the vertiocal coordinates at all
		n_out70p0.y = n_out44p0.y;
	}


// Input:56
	float n_out56p0 = TIME;


// FloatOp:68
	float n_out68p0 = n_out56p0 + n_out65p0;


// FloatOp:59
	float n_in59p1 = 0.01000;
	float n_out59p0 = n_out68p0 * n_in59p1;


// FloatOp:57
	float n_in57p1 = 1.00000;
	float n_out57p0 = mod(n_out59p0, n_in57p1);


// CurveTexture:58
	float n_out58p0 = texture(curve_frg_58, vec2(n_out57p0)).r;


// FloatFunc:60
	float n_out60p0 = round(n_out58p0);


	vec4 n_out2p0;
// Texture2D:2
	n_out2p0 = textureLod(Texture, n_out70p0, n_out60p0);


// VectorDecompose:3
	float n_out3p0 = n_out2p0.x;
	float n_out3p1 = n_out2p0.y;
	float n_out3p2 = n_out2p0.z;
	float n_out3p3 = n_out2p0.w;


// MultiplyAdd:43
	float n_in43p1 = 0.00000;
	float n_out43p0 = fma(n_out37p0, n_in43p1, n_out3p3);


// VectorOp:55
	vec3 n_out55p0 = vec3(n_out2p0.xyz) * vec3(n_out43p0);


// FloatParameter:74
	float n_out74p0 = Emission;


// VectorOp:77
	vec3 n_out77p0 = n_out55p0 * vec3(n_out74p0);


// Output:0
	ALBEDO = vec3(n_out78p0);
	ALPHA = n_out79p0;
	METALLIC = n_out79p0;
	ROUGHNESS = n_out79p0;
	SPECULAR = n_out78p0;
	EMISSION = n_out77p0;


}
