	{
		n_out55p0.x =	cos(n_out56p0) * (n_out10p0.x - n_out51p0.x) + sin(n_out56p0) * (n_out10p0.y - n_out51p0.x) + n_out51p0.y;
		n_out55p0.y = cos(n_out56p0) * (n_out10p0.y - n_out51p0.x) - sin(n_out56p0) * (n_out10p0.x - n_out51p0.y) + n_out51p0.x;
