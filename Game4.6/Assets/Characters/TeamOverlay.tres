[resource]
code = "shader_type spatial;
render_mode cull_front, depth_prepass_alpha, unshaded, shadows_disabled, ambient_light_disabled;

instance uniform float outline_thickness = 4;
instance uniform int team : hint_range(0, 2) = 0;
global uniform vec4 team_color_0 : source_color;
global uniform vec4 team_color_2 : source_color;
global uniform vec4 team_color_1 : source_color;



void vertex() {
// Input:2
	vec3 n_out2p0 = NORMAL;


// FloatParameter:9
	float n_out9p0 = outline_thickness;


// IntConstant:14
	int n_out14p0 = 720;


// FloatOp:7
	float n_out7p0 = n_out9p0 / float(n_out14p0);


// Input:3
	vec3 n_out3p0 = VERTEX;


// MultiplyAdd:4
	vec3 n_out4p0 = fma(n_out2p0, vec3(n_out7p0), n_out3p0);


// Output:0
	VERTEX = n_out4p0;


}

void fragment() {
// IntParameter:23
	int n_out23p0 = team;


// Compare:10
	int n_in10p1 = 0;
	bool n_out10p0 = n_out23p0 == n_in10p1;


// ColorParameter:11
	vec4 n_out11p0 = team_color_0;


// Compare:14
	int n_in14p1 = 2;
	bool n_out14p0 = n_out23p0 == n_in14p1;


// ColorParameter:6
	vec4 n_out6p0 = team_color_2;


// ColorParameter:5
	vec4 n_out5p0 = team_color_1;


	vec3 n_out29p0;
// Switch:29
	n_out29p0 = mix(vec3(n_out5p0.xyz), vec3(n_out6p0.xyz), float(n_out14p0));


	vec3 n_out30p0;
// Switch:30
	n_out30p0 = mix(n_out29p0, vec3(n_out11p0.xyz), float(n_out10p0));


// FloatConstant:24
	float n_out24p0 = 0.900000;


// VectorOp:25
	vec3 n_out25p0 = n_out30p0 * vec3(n_out24p0);


// Input:19
	vec3 n_out19p0 = NORMAL;


// VectorFunc:20
	vec3 n_out20p0 = vec3(1.0) - n_out19p0;


// Output:0
	ALBEDO = n_out25p0;
	NORMAL = n_out20p0;


}
