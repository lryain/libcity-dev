[resource]
code = "shader_type spatial;
render_mode cull_disabled;

uniform sampler2D tex_frg_2;
instance uniform int team : hint_range(0, 2) = 0;
global uniform vec4 team_color_0 : source_color;
global uniform vec4 team_color_2 : source_color;
global uniform vec4 team_color_1 : source_color;
uniform vec2 FaceExpresionSheetCells = vec2(4.000000, 2.000000);
instance uniform int FaceExpression : hint_range(0, 8) = 0;
uniform sampler2D FaceExpressionSheet : source_color, hint_default_transparent, filter_linear_mipmap_anisotropic, repeat_disable;



void fragment() {
// FloatConstant:35
	float n_out35p0 = 0.000000;


// Texture2D:2
	vec4 n_out2p0 = texture(tex_frg_2, UV);


// FloatConstant:36
	float n_out36p0 = 1.000000;


// IntParameter:11
	int n_out11p0 = team;


// Compare:12
	int n_in12p1 = 0;
	bool n_out12p0 = n_out11p0 == n_in12p1;


// ColorParameter:9
	vec4 n_out9p0 = team_color_0;


// Compare:10
	int n_in10p1 = 1;
	bool n_out10p0 = n_out11p0 != n_in10p1;


// ColorParameter:7
	vec4 n_out7p0 = team_color_2;


// ColorParameter:6
	vec4 n_out6p0 = team_color_1;


	vec3 n_out8p0;
// Switch:8
	n_out8p0 = mix(vec3(n_out6p0.xyz), vec3(n_out7p0.xyz), float(n_out10p0));


	vec3 n_out33p0;
// Switch:33
	n_out33p0 = mix(n_out8p0, vec3(n_out9p0.xyz), float(n_out12p0));


	vec3 n_out37p0;
// ColorFunc:37
	{
		vec3 c = n_out33p0;
		vec4 K = vec4(0.0, -1.0 / 3.0, 2.0 / 3.0, -1.0);
		vec4 p = mix(vec4(c.bg, K.wz), vec4(c.gb, K.xy), step(c.b, c.g));
		vec4 q = mix(vec4(p.xyw, c.r), vec4(c.r, p.yzx), step(p.x, c.r));
		float d = q.x - min(q.w, q.y);
		float e = 1.0e-10;
		n_out37p0 = vec3(abs(q.z + (q.w - q.y) / (6.0 * d + e)), d / (q.x + e), q.x);
	}


// VectorOp:42
	vec3 n_in42p1 = vec3(0.00000, 2.00000, 1.50000);
	vec3 n_out42p0 = max(n_out37p0, n_in42p1);


	vec3 n_out38p0;
// ColorFunc:38
	{
		vec3 c = n_out42p0;
		vec4 K = vec4(1.0, 2.0 / 3.0, 1.0 / 3.0, 3.0);
		vec3 p = abs(fract(c.xxx + K.xyz) * 6.0 - K.www);
		n_out38p0 = c.z * mix(K.xxx, clamp(p - K.xxx, 0.0, 1.0), c.y);
	}


// Vector2Parameter:23
	vec2 n_out23p0 = FaceExpresionSheetCells;


// IntParameter:26
	int n_out26p0 = FaceExpression;


// Input:25
	vec2 n_out25p0 = UV;


	vec2 n_out31p0;
// Expression:31
	n_out31p0 = vec2(0.0, 0.0);
	{
		float w = 1.0 / n_out23p0.x;
		float h = 1.0 / n_out23p0.y;
		
		int pos_x = int(mod(float(n_out26p0), n_out23p0.x));
		int pos_y = n_out26p0 / int(n_out23p0.x);
		
		n_out31p0.x = (n_out25p0.x / n_out23p0.x) + (float(pos_x) * w);
		n_out31p0.y = (n_out25p0.y / n_out23p0.y) + (float(pos_y) * h);
	}


	vec4 n_out19p0;
// Texture2D:19
	n_out19p0 = texture(FaceExpressionSheet, n_out31p0);


// VectorDecompose:21
	float n_out21p0 = n_out19p0.x;
	float n_out21p1 = n_out19p0.y;
	float n_out21p2 = n_out19p0.z;
	float n_out21p3 = n_out19p0.w;


// Mix:20
	vec3 n_out20p0 = mix(n_out38p0, vec3(n_out19p0.xyz), vec3(n_out21p3));


// FloatConstant:16
	float n_out16p0 = 0.500000;


// Output:0
	ALBEDO = vec3(n_out35p0);
	ALPHA = n_out2p0.x;
	METALLIC = n_out36p0;
	ROUGHNESS = n_out36p0;
	SPECULAR = n_out35p0;
	EMISSION = n_out20p0;
	ALPHA_SCISSOR_THRESHOLD = n_out16p0;


}
