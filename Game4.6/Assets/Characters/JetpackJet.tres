code = "shader_type spatial;
render_mode unshaded, shadows_disabled;

uniform sampler2D tex_vtx_2;



void vertex() {
// Input:6
	vec3 n_out6p0 = VERTEX;


// Input:3
	float n_out3p0 = TIME;


// Input:4
	vec2 n_out4p0 = UV;


// VectorOp:11
	vec2 n_in11p1 = vec2(0.10000, 0.30000);
	vec2 n_out11p0 = n_out4p0 * n_in11p1;


// MultiplyAdd:5
	vec2 n_in5p1 = vec2(-2.00000, 1.00000);
	vec2 n_out5p0 = fma(vec2(n_out3p0), n_in5p1, n_out11p0);


// Texture2D:2
	vec4 n_out2p0 = texture(tex_vtx_2, n_out5p0);


	float n_out8p0;
// Remap:8
	float n_in8p1 = 0.00000;
	float n_in8p2 = 1.00000;
	float n_in8p3 = -0.30000;
	float n_in8p4 = 0.30000;
	{
		float __input_range = n_in8p2 - n_in8p1;
		float __output_range = n_in8p4 - n_in8p3;
		n_out8p0 = n_in8p3 + __output_range * ((n_out2p0.x - n_in8p1) / __input_range);
	}


// FloatOp:10
	float n_in10p1 = 0.40000;
	float n_out10p0 = pow(n_out8p0, n_in10p1);


// MultiplyAdd:7
	vec3 n_in7p1 = vec3(0.00000, -1.00000, 0.00000);
	vec3 n_out7p0 = fma(vec3(n_out10p0), n_in7p1, n_out6p0);


// VectorOp:9
	vec3 n_out9p0 = min(n_out6p0, n_out7p0);


// Output:0
	VERTEX = n_out9p0;


}

void fragment() {
// ColorConstant:2
	vec4 n_out2p0 = vec4(0.133411, 0.629663, 1.000000, 1.000000);


// FloatConstant:4
	float n_out4p0 = 6.000000;


// VectorOp:3
	vec3 n_out3p0 = vec3(n_out2p0.xyz) * vec3(n_out4p0);


// Output:0
	ALBEDO = n_out3p0;


}
