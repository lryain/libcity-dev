code = "shader_type spatial;
instance uniform vec4 Color : source_color = vec4(0.113281, 0.113281, 0.113281, 1.000000);
instance uniform int team : hint_range(0, 2) = 0;
global uniform vec4 team_color_0 : source_color;
global uniform vec4 team_color_2 : source_color;
global uniform vec4 team_color_1 : source_color;
uniform sampler2D TextureParameterTriplanar;
instance uniform float Emission = 0;


// TextureParameterTriplanar
	vec4 triplanar_texture(sampler2D p_sampler, vec3 p_weights, vec3 p_triplanar_pos) {
		vec4 samp = vec4(0.0);
		samp += texture(p_sampler, p_triplanar_pos.xy) * p_weights.z;
		samp += texture(p_sampler, p_triplanar_pos.xz) * p_weights.y;
		samp += texture(p_sampler, p_triplanar_pos.zy * vec2(-1.0, 1.0)) * p_weights.x;
		return samp;
	}

	uniform vec3 triplanar_scale = vec3(1.0, 1.0, 1.0);
	uniform vec3 triplanar_offset;
	uniform float triplanar_sharpness = 0.5;

	varying vec3 triplanar_power_normal;
	varying vec3 triplanar_pos;

void vertex() {
// TextureParameterTriplanar
	{
		triplanar_power_normal = pow(abs(NORMAL), vec3(triplanar_sharpness));
		triplanar_power_normal /= dot(triplanar_power_normal, vec3(1.0));
		triplanar_pos = VERTEX * triplanar_scale + triplanar_offset;
		triplanar_pos *= vec3(1.0, -1.0, 1.0);
	}
}

void fragment() {
// ColorParameter:2
	vec4 n_out2p0 = Color;


// IntParameter:11
	int n_out11p0 = team;


// Compare:8
	int n_in8p1 = 0;
	bool n_out8p0 = n_out11p0 == n_in8p1;


// ColorParameter:9
	vec4 n_out9p0 = team_color_0;


// Compare:10
	int n_in10p1 = 2;
	bool n_out10p0 = n_out11p0 == n_in10p1;


// ColorParameter:7
	vec4 n_out7p0 = team_color_2;


// ColorParameter:6
	vec4 n_out6p0 = team_color_1;


	vec3 n_out12p0;
// Switch:12
	n_out12p0 = mix(vec3(n_out6p0.xyz), vec3(n_out7p0.xyz), float(n_out10p0));


	vec3 n_out13p0;
// Switch:13
	n_out13p0 = mix(n_out12p0, vec3(n_out9p0.xyz), float(n_out8p0));


// TextureParameterTriplanar:14
	vec4 n_out14p0 = triplanar_texture(TextureParameterTriplanar, triplanar_power_normal, triplanar_pos);


	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(TextureParameterTriplanar, UV);


// SmoothStep:4
	float n_in4p0 = 0.45000;
	float n_in4p1 = 0.55000;
	float n_out4p0 = smoothstep(n_in4p0, n_in4p1, n_out3p0.x);


// Mix:5
	vec3 n_out5p0 = mix(vec3(n_out2p0.xyz), n_out13p0, vec3(n_out4p0));


// FloatParameter:15
	float n_out15p0 = Emission;


// VectorOp:16
	vec3 n_out16p0 = n_out13p0 * vec3(n_out15p0);


// VectorOp:17
	vec3 n_out17p0 = n_out16p0 * vec3(n_out4p0);


// Output:0
	ALBEDO = n_out5p0;
	EMISSION = n_out17p0;


}
"
