[resource]
code = "shader_type spatial;
render_mode cull_front, unshaded;

uniform sampler2D curve_frg_10 : repeat_disable;
uniform float Speed : hint_range(0, 1) = 0;
uniform sampler2D NoiseTexture : source_color, hint_default_black, filter_linear, repeat_enable;



void fragment() {
// Input:4
	vec2 n_out4p0 = UV;


// VectorDecompose:6
	float n_out6p0 = n_out4p0.x;
	float n_out6p1 = n_out4p0.y;


// CurveTexture:10
	float n_out10p0 = texture(curve_frg_10, vec2(n_out6p1)).r;


// Input:3
	float n_out3p0 = TIME;


// MultiplyAdd:12
	float n_in12p1 = 0.20000;
	float n_out12p0 = fma(n_out3p0, n_in12p1, n_out6p0);


// FloatParameter:19
	float n_out19p0 = Speed;


	float n_out20p0;
// Remap:20
	float n_in20p1 = 0.00000;
	float n_in20p2 = 1.00000;
	float n_in20p3 = 0.80000;
	float n_in20p4 = 0.30000;
	{
		float __input_range = n_in20p2 - n_in20p1;
		float __output_range = n_in20p4 - n_in20p3;
		n_out20p0 = n_in20p3 + __output_range * ((n_out19p0 - n_in20p1) / __input_range);
	}


// MultiplyAdd:5
	float n_out5p0 = fma(n_out6p1, n_out20p0, n_out3p0);


// VectorCompose:7
	vec2 n_out7p0 = vec2(n_out12p0, n_out5p0);


	vec4 n_out2p0;
// Texture2D:2
	n_out2p0 = texture(NoiseTexture, n_out7p0);


// MultiplyAdd:15
	float n_in15p1 = -0.20000;
	float n_out15p0 = fma(n_out3p0, n_in15p1, n_out6p0);


// MultiplyAdd:23
	float n_in23p1 = 1.24100;
	float n_in23p2 = 0.40000;
	float n_out23p0 = fma(n_out15p0, n_in23p1, n_in23p2);


// VectorCompose:17
	vec2 n_out17p0 = vec2(n_out23p0, n_out5p0);


	vec4 n_out14p0;
// Texture2D:14
	n_out14p0 = texture(NoiseTexture, n_out17p0);


// FloatOp:18
	float n_out18p0 = n_out2p0.x * n_out14p0.x;


// FloatOp:11
	float n_out11p0 = n_out10p0 * n_out18p0;


// SmoothStep:22
	float n_in22p0 = 0.00000;
	float n_in22p1 = 0.10000;
	float n_out22p0 = smoothstep(n_in22p0, n_in22p1, n_out11p0);


// FloatOp:25
	float n_in25p1 = 0.10000;
	float n_out25p0 = n_out22p0 * n_in25p1;


// FloatOp:26
	float n_in26p1 = 0.50000;
	float n_out26p0 = pow(n_out19p0, n_in26p1);


// FloatOp:24
	float n_out24p0 = n_out25p0 * n_out26p0;


// Input:27
	vec4 n_out27p0 = COLOR;


// VectorDecompose:28
	float n_out28p0 = n_out27p0.x;
	float n_out28p1 = n_out27p0.y;
	float n_out28p2 = n_out27p0.z;
	float n_out28p3 = n_out27p0.w;


// FloatOp:29
	float n_out29p0 = n_out24p0 * n_out28p3;


// Clamp:30
	float n_in30p1 = 0.00000;
	float n_in30p2 = 1.00000;
	float n_out30p0 = clamp(n_out29p0, n_in30p1, n_in30p2);


// FloatOp:31
	float n_in31p1 = 1.50000;
	float n_out31p0 = pow(n_out30p0, n_in31p1);


// FloatOp:32
	float n_in32p1 = 3.00000;
	float n_out32p0 = n_out31p0 * n_in32p1;


// Output:0
	ALPHA = n_out32p0;


}
"
