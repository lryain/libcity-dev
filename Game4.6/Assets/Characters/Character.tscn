// SmoothStep:3
	vec3 n_out3p0 = smoothstep(vec3(n_out4p0), vec3(n_out2p0), vec3(n_out6p0.xyz));


// FloatConstant:7
	float n_out7p0 = 0.500000;


// Output:0
	ALBEDO = n_out3p0;
	ALPHA = n_out7p0;


}
"
