render_mode blend_mix, depth_draw_never, cull_back, diffuse_lambert, specular_disabled, depth_test_disabled, unshaded, shadows_disabled, ambient_light_disabled;

uniform sampler2D screen_tex_frg_6 : hint_screen_texture;



void fragment() {
// FloatConstant:4
	float n_out4p0 = 0.800000;


// FloatConstant:2
	float n_out2p0 = 2.000000;


// Input:5
	vec2 n_out5p0 = SCREEN_UV;


	vec4 n_out6p0;
// Texture2D:6
