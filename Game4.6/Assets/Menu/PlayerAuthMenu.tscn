layout_mode = 2

[node name="RichTextLabel" type="RichTextLabel" parent="CenterContainer/AuthInfo/MarginContainer/VBoxContainer"]
layout_mode = 2
size_flags_vertical = 3
bbcode_enabled = true
text = "[center]Liblast online accounts are optional for the sake of respecting user privacy.
[b]For best experience we recommend using an on-line account.
[/b]It also makes it easier for Liblast developers to track issues and provide help.

[b]Players who choose to register an online account can:[/b][/center]

[ul]Secure one display name as unique among all players in the game network (authenticated or not)
Store user profile (color, face, etc.) and game preferences online, making them accessible from anywhere.
Store befriended and blocked account lists online, accessible from anywhere.
Display user badges, helping to distinguish characters in-game
Track game statistics and achievements (once implemented)
Message other authenticated users (maybe?)[/ul]
Access game servers that [i]require[/i] authentifaction

[center][b]How is user data stored?[/b]

User data is stored on a central Liblast Infrastructure Server and can only be fetched
by the game client and servers after authenticating with a username and password.
User passwords are never stored or transmitted in clear text - only as secure salted hashes.[/center]"
fit_content_height = true
shortcut_keys_enabled = false

