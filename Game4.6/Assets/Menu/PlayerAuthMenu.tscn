[node name="WhyAccount" type="AcceptDialog" parent="CenterContainer/LoginOrNot"]
disable_3d = true
transparent_bg = true
snap_2d_transforms_to_pixel = true
snap_2d_vertices_to_pixel = true
gui_embed_subwindows = true
title = "Why use an account?"
position = Vector2i(64, 64)
size = Vector2i(800, 500)
mode = 2
unresizable = true
borderless = true
transparent = true
content_scale_aspect = 4
theme = ExtResource("5_o3wdj")
dialog_text = "Liblast online accounts are optional for the sake of respecting user privacy, though we do recommend using an on-line account.

For players choosing to use an online account, we are able to provide a few extra things:

1. Secure one chosen display name as unique among all players in the game network (authenticated or not);
2. Store user profile and preferences allowing these to be fetched when playing on a different machine - otherwise this data is only stored locally;
3. Display user badges, helping to distinguish characters  in-game;
4. Track user's game statistics and achievements (once implemented);
5. Possibly allow direct messages between authenticated users (do we want this?);

Also - game servers may require authentifaction, and only allow users using an online account."
dialog_autowrap = true

